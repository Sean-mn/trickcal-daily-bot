generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["bot"]
}

model CheckItem {
  id       Int        @id @default(autoincrement())
  name     String     @unique
  logs     DailyLog[]

  @@schema("bot")
}

model DailyLog {
  id          Int       @id @default(autoincrement())
  userId      String
  date        DateTime  @db.Date
  checkItemId Int
  checkItem   CheckItem @relation(fields: [checkItemId], references: [id])

  @@unique([userId, date, checkItemId])
  @@schema("bot")
}

model UserSetting {
  userId    String  @id
  alarmTime String?

  @@schema("bot")
}

model Notice {
  id        Int      @id @default(autoincrement())
  sourceId  String   @unique
  createdAt DateTime @default(now())

  @@schema("bot")
}
